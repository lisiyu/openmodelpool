{
  "name": "openmodelpool",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "forwardPorts": [8000, 8001, 8443],
  "portsAttributes": {
    "8000": { "label": "openmodelpool HTTP", "visibility": "public", "protocol": "http" },
    "8001": { "label": "seed discovery", "visibility": "private" },
    "8443": { "label": "HTTPS (ACME)", "visibility": "private" }
  },
  "postCreateCommand": "bash .devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": ["golang.go"]
    }
  }
}
