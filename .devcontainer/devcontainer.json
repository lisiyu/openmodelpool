{
  "name": "omp-cmd-test",
  "image": "mcr.microsoft.com/devcontainers/go:1.26",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" }
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": { "label": "cmd-test", "visibility": "public", "protocol": "http" }
  },
  "command": "python3 -m http.server 8000 --bind 0.0.0.0"
}
